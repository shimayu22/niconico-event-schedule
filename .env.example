# Supabase（Dashboard → Project Settings → API）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Route Handler のみ（クライアントに載せない）
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 告知・問い合わせ用 X（@なしのハンドルでも可。表示用）
NEXT_PUBLIC_OFFICIAL_X_HANDLE=your_account

# Cloudflare Turnstile（サイトキーは公開可、シークレットはサーバのみ）
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Discord Incoming Webhook（サーバのみ）
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# 本番の自サイト origin（Discord 文案のリンク用。例: https://your-domain.vercel.app）
NEXT_PUBLIC_SITE_ORIGIN=http://localhost:3000
