---
import SiteNav from "../components/SiteNav.astro";

interface Props {
	metaTitle: string;
	pageHeading: string;
	description?: string;
	mainId?: string;
	navCurrent?: "home" | "upcoming" | "ended";
}

const {
	metaTitle,
	pageHeading,
	description = "ニコニコの投稿祭・イベント情報の非公式一覧。データは公開スプレッドシート由来です。",
	mainId = "main",
	navCurrent,
} = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{metaTitle}</title>
		<meta name="description" content={description} />
	</head>
	<body>
		<a class="skip" href={`#${mainId}`}>本文へスキップ</a>
		<header class="site-header">
			<div class="inner">
				<h1 class="site-title">{pageHeading}</h1>
				<p class="site-tag">このページは個人的に整理している投稿祭の情報を公開している非公式なページです</p>
				<SiteNav current={navCurrent} />
			</div>
		</header>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light dark;
		--bg: light-dark(#f4f6fa, #0f1216);
		--text: light-dark(#111318, #eef0f4);
		--muted: light-dark(#5c6370, #9aa3b2);
		--card-bg: light-dark(#fff, #1a1e24);
		--border: light-dark(#e2e5eb, #2c323c);
		--link: light-dark(#0b57d0, #8ab4f8);
		--link-hover: light-dark(#0948ad, #a8c4fa);
		--accent-line: light-dark(#0b57d0, #6b9ef5);
		--banner-info-bg: light-dark(#e8f0fe, #1a2a44);
		--banner-error-bg: light-dark(#fce8e6, #3c1f1f);
		--banner-error-text: light-dark(#611a15, #f9dedc);
		--radius-sm: 6px;
		--radius-md: 10px;
		--radius-lg: 14px;
		--radius-pill: 999px;
		--shadow-sm: 0 1px 2px rgb(0 0 0 / 0.05);
		--shadow-md: 0 4px 14px rgb(0 0 0 / 0.08);
		--shadow-card-hover: 0 8px 24px rgb(0 0 0 / 0.1);
		/* Card column width (~thumb 360px + padding; symmetric grid) */
		--card-grid-col: 24rem;
		--content-max: min(1240px, calc(100% - 2.5rem));
		font-family:
			system-ui,
			-apple-system,
			"Segoe UI",
			"Hiragino Sans",
			"Hiragino Kaku Gothic ProN",
			"Noto Sans JP",
			sans-serif;
		line-height: 1.5;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
		background: var(--bg);
		color: var(--text);
		-webkit-font-smoothing: antialiased;
	}

	code {
		font-size: 0.88em;
		padding: 0.12em 0.35em;
		border-radius: 4px;
		background: light-dark(rgb(0 0 0 / 0.06), rgb(255 255 255 / 0.08));
	}

	.skip {
		position: absolute;
		left: -9999px;
		top: 0;
		padding: 0.5rem 1rem;
		background: var(--text);
		color: var(--bg);
		z-index: 100;
	}

	.skip:focus {
		left: 0.5rem;
		top: 0.5rem;
	}

	/* Global: applies to slotted <main> from each page */
	.main .inner {
		max-width: var(--content-max);
		margin-inline: auto;
		padding: 1.65rem clamp(1rem, 4vw, 1.35rem) 3rem;
	}

	.banner {
		border-radius: var(--radius-md);
		padding: 1rem 1.15rem;
		margin-bottom: 1.25rem;
		border: 1px solid var(--border);
	}

	.banner-info {
		background: var(--banner-info-bg);
	}

	.banner-error {
		background: var(--banner-error-bg);
		color: var(--banner-error-text);
		border-color: color-mix(in srgb, var(--banner-error-text) 25%, var(--border));
	}

	.banner-title {
		margin: 0 0 0.35rem;
		font-weight: 650;
		font-size: 0.95rem;
	}

	.banner-body {
		margin: 0;
		font-size: 0.875rem;
	}

	.count {
		margin: 0 0 1rem;
		font-size: 0.875rem;
		color: var(--muted);
	}

	/* イベント一覧：モバイル1列・広い画面は固定幅カラムが横に並ぶ */
	ul.grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1.25rem;
		grid-template-columns: 1fr;
		justify-items: stretch;
	}

	ul.grid > li.grid-item {
		list-style: none;
		margin: 0;
		padding: 0;
		min-width: 0;
	}

	ul.grid > li.grid-item::marker {
		content: none;
	}

	@media (min-width: 520px) {
		ul.grid {
			grid-template-columns: repeat(auto-fill, var(--card-grid-col));
			justify-content: center;
		}
	}
</style>

<style>
	.site-header {
		position: relative;
		border-bottom: 1px solid var(--border);
		background: linear-gradient(
			180deg,
			var(--card-bg) 0%,
			color-mix(in srgb, var(--card-bg) 94%, var(--bg)) 100%
		);
		box-shadow: var(--shadow-sm);
	}

	.site-header::before {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		top: 0;
		height: 3px;
		background: linear-gradient(
			90deg,
			color-mix(in srgb, var(--accent-line) 85%, transparent),
			color-mix(in srgb, var(--link) 55%, var(--accent-line))
		);
		opacity: 0.9;
	}

	.inner {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: 1.35rem 1.35rem 1.5rem;
	}

	.site-title {
		margin: 0;
		font-size: clamp(1.2rem, 2.5vw, 1.45rem);
		font-weight: 700;
		letter-spacing: 0.03em;
		line-height: 1.35;
	}

	.site-tag {
		margin: 0.45rem 0 0;
		font-size: 0.8125rem;
		color: var(--muted);
		line-height: 1.5;
		max-width: 42rem;
	}

</style>
