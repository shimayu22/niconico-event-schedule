---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MonthFilter from "../../components/MonthFilter.astro";
import CategoryFilter from "../../components/CategoryFilter.astro";
import BannerLoadError from "../../components/BannerLoadError.astro";
import BannerCsvMissing from "../../components/BannerCsvMissing.astro";
import BannerNoCsvRows from "../../components/BannerNoCsvRows.astro";
import EventGrid from "../../components/EventGrid.astro";
import { loadEventsSafe, isCsvUrlConfigured } from "../../lib/events";
import { calendarDateJST, isEventOngoing } from "../../lib/jst-date";
import { staticPathsForStartMonths } from "../../lib/static-paths";
import {
	eventStartsInMonth,
	formatStartMonthLabelJa,
	isValidYm,
	uniqueStartMonthsDescending,
} from "../../lib/start-month";
import { uniqueCategorySlugsInNiconicoOrder } from "../../lib/categories";

export async function getStaticPaths() {
	return staticPathsForStartMonths((e, ymd) => isEventOngoing(e, ymd));
}

const { ym } = Astro.params;
const ymSafe = typeof ym === "string" && isValidYm(ym) ? ym : "";

const { rows: allEvents, error: loadError } = await loadEventsSafe();
const todayYmd = calendarDateJST();
const activeEvents = allEvents.filter((e) => isEventOngoing(e, todayYmd));
const monthsNav = uniqueStartMonthsDescending(activeEvents);
const categorySlugsNav = uniqueCategorySlugsInNiconicoOrder(activeEvents);
const events = ymSafe ? activeEvents.filter((e) => eventStartsInMonth(e, ymSafe)) : [];
const csvConfigured = isCsvUrlConfigured();
const monthLabel = ymSafe ? formatStartMonthLabelJa(ymSafe) : "";
const metaTitle = ymSafe
	? `${monthLabel}開始 · 開催中 | 投稿祭スケジュール（非公式）`
	: "開催中イベント | 投稿祭スケジュール（非公式）";
---

<BaseLayout
	metaTitle={metaTitle}
	pageHeading={ymSafe ? `${monthLabel}開始 · 開催中` : "開催中イベント"}
	description={ymSafe
		? `開始日が ${monthLabel}の、開催期間内のイベント一覧ページ`
		: undefined}
	navCurrent="home"
>
	<main id="main" class="main">
		<div class="inner">
			{loadError && <BannerLoadError message={loadError} />}

			{!loadError && !csvConfigured && <BannerCsvMissing variant="local" />}

			{
				!loadError && csvConfigured && allEvents.length === 0 && (
					<BannerNoCsvRows />
				)
			}

			{
				!loadError && csvConfigured && categorySlugsNav.length > 0 && (
					<CategoryFilter slugs={categorySlugsNav} currentSlug={null} basePath="" />
				)
			}

			{
				!loadError && csvConfigured && monthsNav.length > 0 && (
					<MonthFilter months={monthsNav} currentYm={ymSafe || null} basePath="" />
				)
			}

			{
				!loadError &&
					csvConfigured &&
					allEvents.length > 0 &&
					activeEvents.length === 0 && (
						<div class="banner banner-info">
							<p class="banner-title">開催中のイベントはありません</p>
							<p class="banner-body">
								<a href="/upcoming/">開催予定イベント</a>・<a href="/ended/">終了イベント</a>
								もご覧ください。
							</p>
						</div>
					)
			}

			{
				!loadError &&
					csvConfigured &&
					activeEvents.length > 0 &&
					events.length === 0 &&
					ymSafe && (
						<div class="banner banner-info">
							<p class="banner-title">この開始月の開催中イベントはありません</p>
							<p class="banner-body">
								<a href="/">開催中イベント（すべて）</a>をご覧ください。
							</p>
						</div>
					)
			}

			{
				events.length > 0 && (
					<p class="count" aria-live="polite">
						{events.length} 件
					</p>
				)
			}

			<EventGrid events={events} />
		</div>
	</main>
</BaseLayout>
