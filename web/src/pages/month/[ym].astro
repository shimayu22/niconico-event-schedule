---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EventCard from "../../components/EventCard.astro";
import MonthFilter from "../../components/MonthFilter.astro";
import CategoryFilter from "../../components/CategoryFilter.astro";
import { loadEvents } from "../../lib/events";
import { calendarDateJST, isEventEnded } from "../../lib/jst-date";
import {
	eventStartsInMonth,
	formatStartMonthLabelJa,
	isValidYm,
	uniqueStartMonthsDescending,
} from "../../lib/start-month";
import { uniqueCategorySlugsInNiconicoOrder } from "../../lib/categories";

export async function getStaticPaths() {
	try {
		const all = await loadEvents();
		const todayYmd = calendarDateJST();
		const active = all.filter((e) => !isEventEnded(e, todayYmd));
		const months = uniqueStartMonthsDescending(active);
		return months.map((ym) => ({ params: { ym } }));
	} catch {
		return [];
	}
}

const { ym } = Astro.params;
const ymSafe = typeof ym === "string" && isValidYm(ym) ? ym : "";

let allEvents: Awaited<ReturnType<typeof loadEvents>> = [];
let loadError: string | null = null;

try {
	allEvents = await loadEvents();
} catch (e) {
	loadError = e instanceof Error ? e.message : String(e);
}

const todayYmd = calendarDateJST();
const activeEvents = allEvents.filter((e) => !isEventEnded(e, todayYmd));
const monthsNav = uniqueStartMonthsDescending(activeEvents);
const categorySlugsNav = uniqueCategorySlugsInNiconicoOrder(activeEvents);
const events = ymSafe ? activeEvents.filter((e) => eventStartsInMonth(e, ymSafe)) : [];

const csvConfigured = Boolean(import.meta.env.PUBLIC_EVENTS_CSV_URL?.trim());
const monthLabel = ymSafe ? formatStartMonthLabelJa(ymSafe) : "";
const metaTitle = ymSafe
	? `${monthLabel}開始のイベント | 投稿祭スケジュール（非公式）`
	: "投稿祭スケジュール（非公式）";
---

<BaseLayout
	metaTitle={metaTitle}
	pageHeading={ymSafe ? `${monthLabel}開始のイベント` : "投稿祭スケジュール"}
	description={ymSafe
		? `開始日が ${monthLabel}（JST の暦月）の掲載中イベント一覧（非公式）。`
		: undefined}
	navCurrent="home"
>
	<main id="main" class="main">
		<div class="inner">
			{
				loadError && (
					<div class="banner banner-error" role="alert">
						<p class="banner-title">データを読み込めませんでした</p>
						<p class="banner-body">{loadError}</p>
					</div>
				)
			}

			{
				!loadError && !csvConfigured && (
					<div class="banner banner-info">
						<p class="banner-title">CSV の URL が未設定です</p>
						<p class="banner-body">
							<code>web/.env</code> に{" "}
							<code>PUBLIC_EVENTS_CSV_URL=（公開 CSV の URL）</code> を設定して開発サーバーを再起動してください。
						</p>
					</div>
				)
			}

			{
				!loadError &&
					csvConfigured &&
					allEvents.length === 0 && (
						<div class="banner banner-info">
							<p class="banner-title">表示する行がありません</p>
							<p class="banner-body">
								CSV に有効な行があるか、列ヘッダーが <code>id</code>, <code>published_at</code> など仕様どおりか確認してください。
							</p>
						</div>
					)
			}

			{
				!loadError && csvConfigured && categorySlugsNav.length > 0 && (
					<CategoryFilter
						slugs={categorySlugsNav}
						currentSlug={null}
						basePath=""
					/>
				)
			}

			{
				!loadError && csvConfigured && monthsNav.length > 0 && (
					<MonthFilter months={monthsNav} currentYm={ymSafe || null} basePath="" />
				)
			}

			{
				!loadError &&
					csvConfigured &&
					allEvents.length > 0 &&
					activeEvents.length === 0 && (
						<div class="banner banner-info">
							<p class="banner-title">掲載中のイベントはありません</p>
							<p class="banner-body">
								終了日（JST）を過ぎたイベントは
								<a href="/ended/">開催終了イベント</a>
								から参照できます。
							</p>
						</div>
					)
			}

			{
				!loadError &&
					csvConfigured &&
					activeEvents.length > 0 &&
					events.length === 0 &&
					ymSafe && (
						<div class="banner banner-info">
							<p class="banner-title">この開始月の掲載中イベントはありません</p>
							<p class="banner-body">
								<a href="/">掲載中のイベント一覧（すべて）</a>をご覧ください。
							</p>
						</div>
					)
			}

			{
				events.length > 0 && (
					<p class="count" aria-live="polite">
						{events.length} 件（{monthLabel}開始 · 掲載日の新しい順）
					</p>
				)
			}

			<ul class="grid" role="list">
				{events.map((event) => (
					<li class="grid-item" role="listitem">
						<EventCard event={event} />
					</li>
				))}
			</ul>
		</div>
	</main>
</BaseLayout>
