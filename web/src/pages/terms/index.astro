---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
	metaTitle="利用規約 | 投稿祭スケジュール（非公式）"
	pageHeading="利用規約"
	description="投稿祭スケジュール（非公式）の利用規約。現在は準備中です。"
>
	<main id="main" class="main">
		<div class="inner">
			<p class="terms-lead">利用規約の本文は準備中です。</p>
			<p class="terms-back">
				<a href="/">トップに戻る</a>
			</p>
		</div>
	</main>
</BaseLayout>

<style>
	.terms-lead {
		margin: 0 0 1.25rem;
		font-size: 0.9375rem;
		line-height: 1.65;
		color: var(--text);
		max-width: 40rem;
	}

	.terms-back {
		margin: 0;
		font-size: 0.875rem;
	}

	.terms-back a {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		color: var(--link);
		font-weight: 600;
		text-decoration: none;
		padding: 0.35rem 0.65rem;
		border-radius: var(--radius-sm);
		border: 1px solid color-mix(in srgb, var(--border) 85%, var(--link));
		background: var(--card-bg);
		transition:
			background 0.15s ease,
			border-color 0.15s ease;
	}

	.terms-back a:hover {
		background: light-dark(rgb(0 0 0 / 0.03), rgb(255 255 255 / 0.06));
		border-color: color-mix(in srgb, var(--link) 35%, var(--border));
	}

	.terms-back a:focus-visible {
		outline: 2px solid var(--link);
		outline-offset: 2px;
	}
</style>
