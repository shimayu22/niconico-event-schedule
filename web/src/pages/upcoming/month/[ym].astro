---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import MonthFilter from "../../../components/MonthFilter.astro";
import CategoryFilter from "../../../components/CategoryFilter.astro";
import BannerLoadError from "../../../components/BannerLoadError.astro";
import BannerCsvMissing from "../../../components/BannerCsvMissing.astro";
import BannerNoCsvRows from "../../../components/BannerNoCsvRows.astro";
import EventGrid from "../../../components/EventGrid.astro";
import { loadEventsSafe, isCsvUrlConfigured } from "../../../lib/events";
import { calendarDateJST, isEventUpcoming } from "../../../lib/jst-date";
import { staticPathsForStartMonths } from "../../../lib/static-paths";
import {
	eventStartsInMonth,
	formatStartMonthLabelJa,
	isValidYm,
	uniqueStartMonthsDescending,
} from "../../../lib/start-month";
import { uniqueCategorySlugsInNiconicoOrder } from "../../../lib/categories";

export async function getStaticPaths() {
	return staticPathsForStartMonths((e, ymd) => isEventUpcoming(e, ymd));
}

const { ym } = Astro.params;
const ymSafe = typeof ym === "string" && isValidYm(ym) ? ym : "";

const { rows: allEvents, error: loadError } = await loadEventsSafe();
const todayYmd = calendarDateJST();
const upcomingEvents = allEvents.filter((e) => isEventUpcoming(e, todayYmd));
const monthsNav = uniqueStartMonthsDescending(upcomingEvents);
const categorySlugsNav = uniqueCategorySlugsInNiconicoOrder(upcomingEvents);
const events = ymSafe ? upcomingEvents.filter((e) => eventStartsInMonth(e, ymSafe)) : [];
const csvConfigured = isCsvUrlConfigured();
const monthLabel = ymSafe ? formatStartMonthLabelJa(ymSafe) : "";
const metaTitle = ymSafe
	? `${monthLabel}開始 · 開催予定 | 投稿祭スケジュール（非公式）`
	: "開催予定イベント | 投稿祭スケジュール（非公式）";
---

<BaseLayout
	metaTitle={metaTitle}
	pageHeading={ymSafe ? `${monthLabel}開始 · 開催予定` : "開催予定イベント"}
	description={ymSafe
		? `開始日が ${monthLabel}（JST の暦月）で、ビルド時点で開催開始前かつ終了日が当日以降のイベント（非公式）。`
		: undefined}
	navCurrent="upcoming"
>
	<main id="main" class="main">
		<div class="inner">
			{loadError && <BannerLoadError message={loadError} />}

			{!loadError && !csvConfigured && <BannerCsvMissing variant="local" />}

			{
				!loadError && csvConfigured && allEvents.length === 0 && (
					<BannerNoCsvRows />
				)
			}

			{
				!loadError && csvConfigured && categorySlugsNav.length > 0 && (
					<CategoryFilter slugs={categorySlugsNav} currentSlug={null} basePath="/upcoming" />
				)
			}

			{
				!loadError && csvConfigured && monthsNav.length > 0 && (
					<MonthFilter months={monthsNav} currentYm={ymSafe || null} basePath="/upcoming" />
				)
			}

			{
				!loadError &&
					csvConfigured &&
					allEvents.length > 0 &&
					upcomingEvents.length === 0 && (
						<div class="banner banner-info">
							<p class="banner-title">開催予定のイベントはありません</p>
							<p class="banner-body">
								<a href="/">開催中イベント</a>・<a href="/ended/">終了イベント</a>
								もご覧ください。
							</p>
						</div>
					)
			}

			{
				!loadError &&
					csvConfigured &&
					upcomingEvents.length > 0 &&
					events.length === 0 &&
					ymSafe && (
						<div class="banner banner-info">
							<p class="banner-title">この開始月の開催予定イベントはありません</p>
							<p class="banner-body">
								<a href="/upcoming/">開催予定イベント（すべて）</a>をご覧ください。
							</p>
						</div>
					)
			}

			{
				events.length > 0 && (
					<p class="count" aria-live="polite">
						{events.length} 件
					</p>
				)
			}

			<EventGrid events={events} />
		</div>
	</main>
</BaseLayout>
