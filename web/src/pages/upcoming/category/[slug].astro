---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import EventCard from "../../../components/EventCard.astro";
import MonthFilter from "../../../components/MonthFilter.astro";
import CategoryFilter from "../../../components/CategoryFilter.astro";
import { loadEvents } from "../../../lib/events";
import { calendarDateJST, isEventUpcoming } from "../../../lib/jst-date";
import { uniqueStartMonthsDescending } from "../../../lib/start-month";
import {
	allNiconicoCategorySlugs,
	categoryLabelFromSlug,
	eventMatchesCategorySlug,
	isValidCategorySlug,
	uniqueCategorySlugsInNiconicoOrder,
} from "../../../lib/categories";

export function getStaticPaths() {
	return allNiconicoCategorySlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const slugSafe =
	typeof slug === "string" && isValidCategorySlug(slug) ? slug : "";

let allEvents: Awaited<ReturnType<typeof loadEvents>> = [];
let loadError: string | null = null;

try {
	allEvents = await loadEvents();
} catch (e) {
	loadError = e instanceof Error ? e.message : String(e);
}

const todayYmd = calendarDateJST();
const upcomingEvents = allEvents.filter((e) => isEventUpcoming(e, todayYmd));
const monthsNav = uniqueStartMonthsDescending(upcomingEvents);
const categorySlugsNav = uniqueCategorySlugsInNiconicoOrder(upcomingEvents);
const events = slugSafe
	? upcomingEvents.filter((e) => eventMatchesCategorySlug(e, slugSafe))
	: [];

const csvConfigured = Boolean(import.meta.env.PUBLIC_EVENTS_CSV_URL?.trim());
const categoryLabel = slugSafe ? categoryLabelFromSlug(slugSafe) : "";
const metaTitle = categoryLabel
	? `${categoryLabel} · 開催予定 | 投稿祭スケジュール（非公式）`
	: "開催予定イベント | 投稿祭スケジュール（非公式）";
---

<BaseLayout
	metaTitle={metaTitle}
	pageHeading={categoryLabel ? `${categoryLabel} · 開催予定` : "開催予定イベント"}
	description={
		categoryLabel
			? `カテゴリ「${categoryLabel}」`
			: undefined
	}
	navCurrent="upcoming"
>
	<main id="main" class="main">
		<div class="inner">
			{
				loadError && (
					<div class="banner banner-error" role="alert">
						<p class="banner-title">データを読み込めませんでした</p>
						<p class="banner-body">{loadError}</p>
					</div>
				)
			}

			{
				!loadError && !csvConfigured && (
					<div class="banner banner-info">
						<p class="banner-title">CSV の URL が未設定です</p>
						<p class="banner-body">
							<code>web/.env</code> に{" "}
							<code>PUBLIC_EVENTS_CSV_URL=（公開 CSV の URL）</code> を設定して開発サーバーを再起動してください。
						</p>
					</div>
				)
			}

			{
				!loadError &&
					csvConfigured &&
					allEvents.length === 0 && (
						<div class="banner banner-info">
							<p class="banner-title">表示する行がありません</p>
							<p class="banner-body">
								CSV に有効な行があるか、列ヘッダーが <code>id</code>, <code>published_at</code> など仕様どおりか確認してください。
							</p>
						</div>
					)
			}

			{
				!loadError && csvConfigured && categorySlugsNav.length > 0 && (
					<CategoryFilter
						slugs={categorySlugsNav}
						currentSlug={slugSafe || null}
						basePath="/upcoming"
					/>
				)
			}

			{
				!loadError && csvConfigured && monthsNav.length > 0 && (
					<MonthFilter months={monthsNav} currentYm={null} basePath="/upcoming" />
				)
			}

			{
				!loadError &&
					csvConfigured &&
					allEvents.length > 0 &&
					upcomingEvents.length === 0 && (
						<div class="banner banner-info">
							<p class="banner-title">開催予定のイベントはありません</p>
							<p class="banner-body">
								<a href="/">開催中イベント</a>・<a href="/ended/">終了イベント</a>
								もご覧ください。
							</p>
						</div>
					)
			}

			{
				!loadError &&
					csvConfigured &&
					upcomingEvents.length > 0 &&
					events.length === 0 &&
					slugSafe && (
						<div class="banner banner-info">
							<p class="banner-title">このカテゴリの開催予定イベントはありません</p>
							<p class="banner-body">
								<a href="/upcoming/">開催予定イベント（すべて）</a>をご覧ください。
							</p>
						</div>
					)
			}

			{
				events.length > 0 && (
					<p class="count" aria-live="polite">
						{events.length} 件
					</p>
				)
			}

			<ul class="grid" role="list">
				{events.map((event) => (
					<li class="grid-item" role="listitem">
						<EventCard event={event} />
					</li>
				))}
			</ul>
		</div>
	</main>
</BaseLayout>
